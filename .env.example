# Knowledge Tree — Quickstart Environment
#
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# At minimum you need OPENROUTER_API_KEY for LLM calls.
# HATCHET_CLIENT_TOKEN is generated automatically on first startup.

# ── Required ──────────────────────────────────────────────────────

# OpenRouter API key (https://openrouter.ai/keys) — powers all LLM calls
OPENROUTER_API_KEY=

# ── Search Providers (at least one recommended) ───────────────────

# Serper API key (https://serper.dev/) — default search provider
SERPER_KEY=

# Brave Search API key (https://brave.com/search/api/) — alternative provider
BRAVE_KEY=

# ── Optional ──────────────────────────────────────────────────────

# OpenAI API key — used for embeddings (text-embedding-3-large via OpenRouter)
# If not set, embeddings go through OpenRouter using OPENROUTER_API_KEY
OPENAI_API_KEY=

# JWT secret for authentication tokens (auto-generated if empty)
JWT_SECRET_KEY=change-me-in-production

# Hatchet workflow engine token (auto-generated on first startup)
HATCHET_CLIENT_TOKEN=
