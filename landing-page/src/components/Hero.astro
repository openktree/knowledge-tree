<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">Knowledge Tree</h1>
    <p class="hero-tagline">An open knowledge commons for humanity</p>
    <p class="hero-description">
      A living World Graph built from raw data, where every fact is
      provenance-tracked, every perspective is preserved, and multiple AI models
      reveal genuine consensus through convergence.
    </p>
    <div class="hero-actions">
      <a href="https://wiki.openktree.com" class="btn btn-primary"
        >Explore the Wiki</a
      >
      <a href="https://docs.openktree.com" class="btn btn-outline"
        >Read the Docs</a
      >
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-nav-bg);
    padding: 6rem 2rem 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
        ellipse at 20% 50%,
        rgba(30, 99, 168, 0.08) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse at 80% 50%,
        rgba(26, 107, 66, 0.06) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse at 50% 80%,
        rgba(124, 78, 40, 0.05) 0%,
        transparent 50%
      );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .hero-tagline {
    font-size: 1.4rem;
    color: var(--ocean-mid);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .hero-description {
    font-size: 1.1rem;
    color: var(--color-nav-text);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    opacity: 0.85;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: all var(--t-base);
    cursor: pointer;
  }

  .btn-primary {
    background: var(--ocean);
    color: #fff;
    border: 1px solid var(--ocean);
  }

  .btn-primary:hover {
    background: var(--ocean-mid);
    border-color: var(--ocean-mid);
    color: #fff;
  }

  .btn-outline {
    background: transparent;
    color: var(--color-nav-text);
    border: 1px solid var(--color-nav-border);
  }

  .btn-outline:hover {
    border-color: var(--color-nav-text);
    color: #fff;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 4rem 1.5rem 3rem;
    }
    .hero-title {
      font-size: 2.5rem;
    }
    .hero-tagline {
      font-size: 1.1rem;
    }
  }
</style>
